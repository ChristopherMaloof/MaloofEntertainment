                <div class="footer-column">
                    <h3>CONTACT</h3>
                    <a href="mailto:maloofentertainment@gmail.com" class="footer-link">maloofentertainment@gmail.com</a>
                    <a href="tel:813-738-2444" class="footer-link">813-738-2444</a>
                </div>
                
                <div class="footer-column">
                    <h3>SCHEDULE</h3>
                    <p>Every 2nd Sunday<br>3:00 PM - 7:00 PM<br>809 Restaurant & Lounge</p>
