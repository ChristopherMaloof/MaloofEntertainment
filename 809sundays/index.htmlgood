            <div style="margin-top: 40px; padding-top: 30px; border-top: 1px solid rgba(245, 230, 211, 0.2);">
                <p style="font-size: 14px;">Classic Salsa Sundays is an event by<br>
                <a href="https://www.maloofentertainment.com" class="footer-link" style="font-weight: 700;">MALOOF ENTERTAINMENT</a></p>
                <p class="footer-venue-promo">We help make your venue shine. <a href="https://www.maloofentertainment.com">Contact us!</a></p>
            </div>
            
            <div class="copyright">
                <p>© 2025 Classic Salsa Sundays. All Rights Reserved.</p>
            </div>
        </div>
    </footer>

    <!-- JavaScript -->
    <script>
        // FAQ Accordion
        function toggleFAQ(element) {
            const faqItem = element.parentElement;
            const isActive = faqItem.classList.contains('active');
            
            // Close all FAQ items
            document.querySelectorAll('.faq-item').forEach(item => {
                item.classList.remove('active');
            });
            
            // Open clicked item if it wasn't active
            if (!isActive) {
                faqItem.classList.add('active');
            }
        }
        
        // Song Request Form Handler
        function handleSongRequestSubmit(event) {
            event.preventDefault();
            const form = event.target;
            const submitButton = form.querySelector('button[type="submit"]');
            const originalText = submitButton.textContent;
            
            // Show loading state
            submitButton.textContent = 'SENDING...';
            submitButton.disabled = true;
            
            const songTitle = form.querySelector('#song-title');
            const songArtist = form.querySelector('#song-artist');
            
            let isValid = true;

            // Reset error states
            [songTitle, songArtist].forEach(input => {
                const errorId = input.id + '-error';
                const error = form.querySelector(`#${errorId}`);
                if (error) {
                    error.classList.remove('visible');
                    input.classList.remove('border-red');
                }
            });

            // Validate song title
            if (!songTitle.value.trim()) {
                form.querySelector('#song-title-error').classList.add('visible');
                songTitle.classList.add('border-red');
                isValid = false;
            }
            
            // Validate artist
            if (!songArtist.value.trim()) {
                form.querySelector('#song-artist-error').classList.add('visible');
                songArtist.classList.add('border-red');
                isValid = false;
            }

            if (isValid) {
                // Submit form
                fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: {
                        'Accept': 'application/json'
                    }
                }).then(response => {
                    if (response.ok) {
                        form.reset();
                        document.getElementById('song-success-message').classList.add('visible');
                        setTimeout(() => {
                            document.getElementById('song-success-message').classList.remove('visible');
                        }, 5000);
                    } else {
                        alert('There was an error. Please try again or text us at 813-738-2444.');
                    }
                }).catch(() => {
                    alert('There was an error. Please try again or text us at 813-738-2444.');
                }).finally(() => {
                    submitButton.textContent = originalText;
                    submitButton.disabled = false;
                });
            } else {
                submitButton.textContent = originalText;
                submitButton.disabled = false;
            }
        }
        
        // Form Submission Handler
        function handleFormSubmit(event) {
            event.preventDefault();
            const form = event.target;
            const submitButton = form.querySelector('button[type="submit"]');
            const originalText = submitButton.textContent;
            
            // Show loading state
            submitButton.textContent = 'SENDING...';
            submitButton.disabled = true;
            
            const name = form.querySelector('#name');
            const phone = form.querySelector('#phone');
            const email = form.querySelector('#email');
            
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            let isValid = true;

            // Reset error states
            [name, phone, email].forEach(input => {
                const errorId = input.id + '-error';
                const error = form.querySelector(`#${errorId}`);
                if (error) {
                    error.classList.remove('visible');
                    input.classList.remove('border-red');
                }
            });

            // Validate name
            if (!name.value.trim()) {
                form.querySelector('#name-error').classList.add('visible');
                name.classList.add('border-red');
                isValid = false;
            }
            
            // Validate email
            if (!emailRegex.test(email.value)) {
                form.querySelector('#email-error').classList.add('visible');
                email.classList.add('border-red');
                isValid = false;
            }
            
            // Validate phone only if provided
            if (phone.value.trim()) {
                const cleanPhone = phone.value.replace(/\D/g, '');
                if (cleanPhone.length < 10) {
                    form.querySelector('#phone-error').classList.add('visible');
                    phone.classList.add('border-red');
                    isValid = false;
                }
            }

            if (isValid) {
                // Submit form
                fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: {
                        'Accept': 'application/json'
                    }
                }).then(response => {
                    if (response.ok) {
                        form.reset();
                        document.getElementById('success-message').classList.add('visible');
                        setTimeout(() => {
                            document.getElementById('success-message').classList.remove('visible');
                        }, 5000);
                    } else {
                        alert('There was an error. Please try again or call us at 813-738-2444.');
                    }
                }).catch(() => {
                    alert('There was an error. Please try again or call us at 813-738-2444.');
                }).finally(() => {
                    submitButton.textContent = originalText;
                    submitButton.disabled = false;
                });
            } else {
                submitButton.textContent = originalText;
                submitButton.disabled = false;
            }
        }
        
        // Calendar Download Function
        function downloadCalendar() {
            const event = {
                title: 'Classic Salsa Sundays',
                description: 'Preserve authentic Salsa culture with free dance lesson, DJ Washington Party, and real Latino food. NO COVER.',
                location: '809 Restaurant & Lounge, 3710 West Waters Avenue, Tampa, FL 33614',
                start: '20251207T150000',
                end: '20251207T190000',
                rrule: 'FREQ=MONTHLY;BYDAY=2SU'
            };
            
            const icsContent = [
                'BEGIN:VCALENDAR',
                'VERSION:2.0',
                'PRODID:-//Classic Salsa Sundays//EN',
                'BEGIN:VEVENT',
                `DTSTART:${event.start}`,
                `DTEND:${event.end}`,
                `SUMMARY:${event.title}`,
                `DESCRIPTION:${event.description}`,
                `LOCATION:${event.location}`,
                `RRULE:${event.rrule}`,
                'END:VEVENT',
                'END:VCALENDAR'
            ].join('\r\n');
            
            const blob = new Blob([icsContent], { type: 'text/calendar' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = 'classic-salsa-sundays.ics';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }
        
        // Smooth Scrolling
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>
</body>
</html>